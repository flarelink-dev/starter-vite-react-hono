{
  "name": "flarelink-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "dotenv -e .dev.vars -- wrangler d1 migrations apply notes --local",
    "db:migrate:remote": "dotenv -e .dev.vars -- wrangler d1 migrations apply notes --remote"
  },
  "dependencies": {
    "@flarelink/client": "^0.2.0",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
